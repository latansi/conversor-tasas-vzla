      replacement_content: "interface RateData {\n  usdt_ves: { buy: number; sell: number; change: number };\n  usd_ves: { official: number; change: number };\n}\n"
    }
    replacement_chunks {
      target_content: "          <section className=\"grid grid-cols-1 gap-4 sm:grid-cols-3\">\n            <RateCard title=\"USDT / VES (Venta)\" value={`Bs. ${data.usdt_ves.sell}`} change={data.usdt_ves.change} />\n            <RateCard title=\"USD / VES (Oficial)\" value={`Bs. ${data.usd_ves.official}`} change={data.usd_ves.change} />\n            <RateCard title=\"USDT / VES (Compra)\" value={`Bs. ${data.usdt_ves.buy}`} change={data.usdt_ves.change} />\n          </section>\n\n          <section className=\"rounded-2xl bg-slate-900 p-6 shadow-xl\">\n             <div className=\"mb-4 flex items-center gap-2\">\n                <TrendingUp className=\"text-yellow-400\" />\n                <h2 className=\"text-lg font-semibold text-slate-100\">Variaci\303\263n Semanal</h2>\n             </div>\n            <div className=\"h-64\">\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <LineChart data={data.history}>\n                  <XAxis dataKey=\"day\" stroke=\"#94a3b8\" />\n                  <YAxis stroke=\"#94a3b8\" />\n                  <Tooltip contentStyle={{ backgroundColor: \'#0f172a\', borderColor: \'#334155\' }} />\n                  <Line type=\"monotone\" dataKey=\"value\" stroke=\"#facc15\" strokeWidth={3} />\n                </LineChart>\n              </ResponsiveContainer>\n            </div>\n          </section>\n        </main>\n      )}\n    </div>\n  );\n}\n"
      replacement_content: "          <section className=\"grid grid-cols-1 gap-4 sm:grid-cols-3\">\n            <RateCard title=\"USDT / VES (Venta)\" value={`Bs. ${data.usdt_ves.sell}`} change={data.usdt_ves.change} />\n            <RateCard title=\"USD / VES (Oficial)\" value={`Bs. ${data.usd_ves.official}`} change={data.usd_ves.change} />\n            <RateCard title=\"USDT / VES (Compra)\" value={`Bs. ${data.usdt_ves.buy}`} change={data.usdt_ves.change} />\n          </section>\n\n          <ConverterCard data={data} />\n        </main>\n      )}\n    </div>\n  );\n}\n\nfunction ConverterCard({ data }: { data: RateData }) {\n  const [amount, setAmount] = useState<number>(1);\n  const [type, setType] = useState<\'usdt_buy\' | \'usdt_sell\' | \'usd_official\'>(\'usdt_sell\');\n\n  const getRate = () => {\n    switch (type) {\n      case \'usdt_buy\': return data.usdt_ves.buy;\n      case \'usdt_sell\': return data.usdt_ves.sell;\n      case \'usd_official\': return data.usd_ves.official;\n    }\n  };\n\n  const result = (amount * getRate()).toFixed(2);\n\n  return (\n    <section className=\"rounded-2xl bg-slate-900 p-6 border border-slate-800 shadow-xl space-y-4\">\n      <div className=\"flex items-center gap-2 mb-2\">\n        <Calculator className=\"text-yellow-400\" />\n        <h2 className=\"text-lg font-semibold text-slate-100\">Calculadora</h2>\n      </div>\n      \n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n        <input\n          type=\"number\"\n          value={amount}\n          onChange={(e) => setAmount(Number(e.target.value))}\n          className=\"w-full bg-slate-800 border border-slate-700 p-3 rounded-lg text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n          placeholder=\"Monto\"\n        />\n        <select\n          value={type}\n          onChange={(e) => setType(e.target.value as any)}\n          className=\"w-full bg-slate-800 border border-slate-700 p-3 rounded-lg text-slate-100 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n        >\n          <option value=\"usdt_sell\">USDT Venta</option>\n          <option value=\"usdt_buy\">USDT Compra</option>\n          <option value=\"usd_official\">USD Oficial</option>\n        </select>\n      </div>\n\n      <div className=\"mt-4 pt-4 border-t border-slate-800 flex justify-between items-center\">\n        <span className=\"text-slate-400\">Total equivalente</span>\n        <span className=\"text-3xl font-bold text-yellow-500\">Bs. {result}</span>\n      </div>\n    </section>\n  );\n}\n"
    }
