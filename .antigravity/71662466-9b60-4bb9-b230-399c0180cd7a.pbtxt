  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  return (\n    <div className=\"min-h-screen bg-slate-950 p-6 font-sans text-slate-100\">\n      <header className=\"mb-8 flex items-center justify-between\">\n        <h1 className=\"text-2xl font-bold tracking-tight text-yellow-400\">Tasas Vzla</h1>\n        <button \n          onClick={fetchData} \n          className=\"rounded-full bg-slate-800 p-2 text-yellow-400 transition hover:bg-slate-700\"\n        >\n          <RefreshCcw className={`h-5 w-5 ${loading ? \'animate-spin\' : \'\'}`} />\n        </button>\n      </header>\n\n      {data && (\n        <main className=\"space-y-6\">\n          <section className=\"grid grid-cols-1 gap-4 sm:grid-cols-3\">\n            <RateCard title=\"USDT / VES (Venta)\" value={`Bs. ${data.usdt_ves.sell}`} change={data.usdt_ves.change} />\n            <RateCard title=\"USD / VES (Oficial)\" value={`Bs. ${data.usd_ves.official}`} change={data.usd_ves.change} />\n            <RateCard title=\"USDT / VES (Compra)\" value={`Bs. ${data.usdt_ves.buy}`} change={data.usdt_ves.change} />\n          </section>\n\n          <ConverterCard data={data} />\n        </main>\n      )}\n    </div>\n  );\n}\n\nfunction ConverterCard({ data }: { data: RateData }) {\n  const [amount, setAmount] = useState<number>(1);\n  const [type, setType] = useState<\'usdt_buy\' | \'usdt_sell\' | \'usd_official\'>(\'usdt_sell\');\n\n  const getRate = () => {\n    switch (type) {\n      case \'usdt_buy\': return data.usdt_ves.buy;\n      case \'usdt_sell\': return data.usdt_ves.sell;\n      case \'usd_official\': return data.usd_ves.official;\n    }\n  };\n\n  const result = (amount * getRate()).toFixed(2);\n\n  return (\n    <section className=\"rounded-2xl bg-slate-900 p-6 border border-slate-800 shadow-xl space-y-4\">\n      <div className=\"flex items-center gap-2 mb-2\">\n        <Calculator className=\"text-yellow-400\" />\n        <h2 className=\"text-lg font-semibold text-slate-100\">Calculadora</h2>\n      </div>\n      \n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n        <input\n          type=\"number\"\n          value={amount}\n          onChange={(e) => setAmount(Number(e.target.value))}\n          className=\"w-full bg-slate-800 border border-slate-700 p-3 rounded-lg text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n          placeholder=\"Monto\"\n        />\n        <select\n          value={type}\n          onChange={(e) => setType(e.target.value as any)}\n          className=\"w-full bg-slate-800 border border-slate-700 p-3 rounded-lg text-slate-100 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n        >\n          <option value=\"usdt_sell\">USDT Venta</option>\n          <option value=\"usdt_buy\">USDT Compra</option>\n          <option value=\"usd_official\">USD Oficial</option>\n        </select>\n      </div>\n\n      <div className=\"mt-4 pt-4 border-t border-slate-800 flex justify-between items-center\">\n        <span className=\"text-slate-400\">Total equivalente</span>\n        <span className=\"text-3xl font-bold text-yellow-500\">Bs. {result}</span>\n      </div>\n    </section>\n  );\n}\n\nfunction RateCard({ title, value, change }: { title: string; value: string; change: number }) {\n  return (\n    <div className=\"rounded-2xl bg-slate-900 p-6 border border-slate-800\">\n      <p className=\"mb-1 text-sm text-slate-400\">{title}</p>\n      <p className=\"text-3xl font-bold text-yellow-400\">{value}</p>\n      <p className={`text-sm ${change >= 0 ? \'text-emerald-400\' : \'text-rose-400\'}`}>\n        {change > 0 ? \'+\' : \'\'}{change}%\n      </p>\n    </div>\n  );\n}"
      replacement_content: "  return (\n    <div className=\"flex h-dvh flex-col bg-slate-950 p-4 font-sans text-slate-100\">\n      <header className=\"mb-4 flex flex-shrink-0 items-center justify-between\">\n        <h1 className=\"text-xl font-bold tracking-tight text-yellow-400\">Tasas Vzla</h1>\n        <button \n          onClick={fetchData} \n          className=\"rounded-full bg-slate-800 p-2 text-yellow-400 transition hover:bg-slate-700\"\n        >\n          <RefreshCcw className={`h-5 w-5 ${loading ? \'animate-spin\' : \'\'}`} />\n        </button>\n      </header>\n\n      {data && (\n        <main className=\"flex flex-grow flex-col gap-4 overflow-hidden\">\n          <section className=\"grid flex-shrink-0 grid-cols-2 gap-3\">\n            <RateCard title=\"USDT Venta\" value={`Bs. ${data.usdt_ves.sell}`} change={data.usdt_ves.change} />\n            <RateCard title=\"USD Ofic.\" value={`Bs. ${data.usd_ves.official}`} change={data.usd_ves.change} />\n          </section>\n\n          <ConverterCard data={data} />\n        </main>\n      )}\n    </div>\n  );\n}\n\nfunction ConverterCard({ data }: { data: RateData }) {\n  const [amount, setAmount] = useState<number>(1);\n  const [type, setType] = useState<\'usdt_buy\' | \'usdt_sell\' | \'usd_official\'>(\'usdt_sell\');\n\n  const getRate = () => {\n    switch (type) {\n      case \'usdt_buy\': return data.usdt_ves.buy;\n      case \'usdt_sell\': return data.usdt_ves.sell;\n      case \'usd_official\': return data.usd_ves.official;\n    }\n  };\n\n  const result = (amount * getRate()).toFixed(2);\n\n  return (\n    <section className=\"flex flex-shrink-0 flex-col rounded-2xl bg-slate-900 p-4 border border-slate-800 shadow-xl\">\n      <div className=\"flex items-center gap-2 mb-3\">\n        <Calculator className=\"h-5 w-5 text-yellow-400\" />\n        <h2 className=\"text-base font-semibold text-slate-100\">Calculadora</h2>\n      </div>\n      \n      <div className=\"grid grid-cols-2 gap-2 mb-3\">\n        <input\n          type=\"number\"\n          value={amount}\n          onChange={(e) => setAmount(Number(e.target.value))}\n          className=\"w-full bg-slate-800 border border-slate-700 p-2 rounded-lg text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n          placeholder=\"Monto\"\n        />\n        <select\n          value={type}\n          onChange={(e) => setType(e.target.value as any)}\n          className=\"w-full bg-slate-800 border border-slate-700 p-2 rounded-lg text-slate-100 focus:outline-none focus:ring-2 focus:ring-yellow-500\"\n        >\n          <option value=\"usdt_sell\">USDT Venta</option>\n          <option value=\"usdt_buy\">USDT Compra</option>\n          <option value=\"usd_official\">USD Oficial</option>\n        </select>\n      </div>\n\n      <div className=\"pt-3 border-t border-slate-800 flex justify-between items-center\">\n        <span className=\"text-sm text-slate-400\">Total</span>\n        <span className=\"text-2xl font-bold text-yellow-500\">Bs. {result}</span>\n      </div>\n    </section>\n  );\n}\n\nfunction RateCard({ title, value, change }: { title: string; value: string; change: number }) {\n  return (\n    <div className=\"rounded-2xl bg-slate-900 p-4 border border-slate-800\">\n      <p className=\"mb-1 text-xs text-slate-400\">{title}</p>\n      <p className=\"text-xl font-bold text-yellow-400\">{value}</p>\n      <p className={`text-xs ${change >= 0 ? \'text-emerald-400\' : \'text-rose-400\'}`}>\n        {change > 0 ? \'+\' : \'\'}{change}%\n      </p>\n    </div>\n  );\n}"
