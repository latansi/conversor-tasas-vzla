    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH4HY6G7RxSq9xgcYjcuCBPjavkceQ4qkf98UvaNFwxh6DB8ty601wQZXEZxihRAE19sFXyFeUmaYWqNrY_Kox7llJMNEfyXLnyWKRnPm__gg=="
