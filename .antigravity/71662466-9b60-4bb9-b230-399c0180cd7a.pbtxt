    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHc1B5v34kz0bg9YWTsODi4E2ZGq3e0NiPDuvVglVWPgv4cgjbrxRjJyz_j7kabuB8poADxtnn9z36PFrVtJN1VsQYqiHvM5wOzzT82zXCteFbIhdxMOizH8rJa_GY="
