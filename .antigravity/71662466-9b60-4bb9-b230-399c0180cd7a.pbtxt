    replacement_chunks {
      target_content: "export default function App() {\n  return <div></div>;\n}\n"
      replacement_content: "import { useState, useEffect, useCallback } from \'react\';\nimport { Loader2, RefreshCcw, TrendingUp } from \'lucide-react\';\nimport { LineChart, Line, XAxis, YAxis, Tooltip, ResponsiveContainer } from \'recharts\';\n\ninterface RateData {\n  usdt_ves: { buy: number; sell: number; change: number };\n  usd_ves: { official: number; change: number };\n  history: { day: string; value: number }[];\n}\n\nexport default function App() {\n  const [data, setData] = useState<RateData | null>(null);\n  const [loading, setLoading] = useState(true);\n\n  const fetchData = useCallback(async () => {\n    setLoading(true);\n    try {\n      const response = await fetch(\'/api/rates\');\n      const json = await response.json();\n      setData(json);\n    } catch (error) {\n      console.error(\'Failed to fetch rates\', error);\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchData();\n  }, [fetchData]);\n\n  if (loading && !data) return (\n    <div className=\"flex h-screen items-center justify-center bg-slate-950 text-yellow-400\">\n      <Loader2 className=\"h-8 w-8 animate-spin\" />\n    </div>\n  );\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 p-6 font-sans text-slate-100\">\n      <header className=\"mb-8 flex items-center justify-between\">\n        <h1 className=\"text-2xl font-bold tracking-tight text-yellow-400\">Tasas Vzla</h1>\n        <button \n          onClick={fetchData} \n          className=\"rounded-full bg-slate-800 p-2 text-yellow-400 transition hover:bg-slate-700\"\n        >\n          <RefreshCcw className={`h-5 w-5 ${loading ? \'animate-spin\' : \'\'}`} />\n        </button>\n      </header>\n\n      {data && (\n        <main className=\"space-y-6\">\n          <section className=\"grid grid-cols-1 gap-4 sm:grid-cols-3\">\n            <RateCard title=\"USDT / VES (Venta)\" value={`Bs. ${data.usdt_ves.sell}`} change={data.usdt_ves.change} />\n            <RateCard title=\"USD / VES (Oficial)\" value={`Bs. ${data.usd_ves.official}`} change={data.usd_ves.change} />\n            <RateCard title=\"USDT / VES (Compra)\" value={`Bs. ${data.usdt_ves.buy}`} change={data.usdt_ves.change} />\n          </section>\n\n          <section className=\"rounded-2xl bg-slate-900 p-6 shadow-xl\">\n             <div className=\"mb-4 flex items-center gap-2\">\n                <TrendingUp className=\"text-yellow-400\" />\n                <h2 className=\"text-lg font-semibold text-slate-100\">Variaci\303\263n Semanal</h2>\n             </div>\n            <div className=\"h-64\">\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <LineChart data={data.history}>\n                  <XAxis dataKey=\"day\" stroke=\"#94a3b8\" />\n                  <YAxis stroke=\"#94a3b8\" />\n                  <Tooltip contentStyle={{ backgroundColor: \'#0f172a\', borderColor: \'#334155\' }} />\n                  <Line type=\"monotone\" dataKey=\"value\" stroke=\"#facc15\" strokeWidth={3} />\n                </LineChart>\n              </ResponsiveContainer>\n            </div>\n          </section>\n        </main>\n      )}\n    </div>\n  );\n}\n\nfunction RateCard({ title, value, change }: { title: string; value: string; change: number }) {\n  return (\n    <div className=\"rounded-2xl bg-slate-900 p-6 border border-slate-800\">\n      <p className=\"mb-1 text-sm text-slate-400\">{title}</p>\n      <p className=\"text-3xl font-bold text-yellow-400\">{value}</p>\n      <p className={`text-sm ${change >= 0 ? \'text-emerald-400\' : \'text-rose-400\'}`}>\n        {change > 0 ? \'+\' : \'\'}{change}%\n      </p>\n    </div>\n  );\n}\n"
    }
